{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "scripts": {
    "build": "pnpm --recursive run build",
    "check": "tsc -b tsconfig.json",
    "clean": "pnpm --recursive exec rm -rf dist",
    "effect-solutions": "effect-solutions",
    "lint": "eslint \"**/src/**/*.{ts,mjs}\"",
    "lint-fix": "pnpm lint --fix",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "changeset-version": "changeset version",
    "changeset-publish": "pnpm build && changeset publish",
    "prepare": "husky && effect-language-service patch"
  },
  "lint-staged": {
    "*.{ts,mjs}": "eslint --fix",
    "*.json": "dprint fmt"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.87.1",
    "@types/node": "^22",
    "bun": "^1.3.14",
    "dprint": "^0.55.2",
    "effect-solutions": "^0.5.3",
    "eslint": "^10.7.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "fallow": "^3.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "tsdown": "^0.22.13",
    "tsx": "^4.23.1",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.65.0"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1"
  }
