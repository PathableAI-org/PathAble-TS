{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": true,
  "packageRules": [
    {
      "description": "Group Effect ecosystem dependencies and require manual review",
      "matchPackagePrefixes": ["@effect/", "effect"],
      "groupName": "effect-ecosystem",
      "automerge": false
    },
    {
      "description": "Group TypeScript 7 native and 6 compat packages to stay in sync",
      "matchPackageNames": ["@typescript/native", "typescript"],
      "groupName": "typescript",
      "automerge": false
    }
  ]
}